# dsimaging-store configuration
# Copy to .env and edit as needed

# MinIO credentials (change in production!)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Ports
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
CONTROLLER_PORT=8080

# Bucket name for imaging datasets
BUCKET_NAME=imaging-data

# Controller debounce/reconcile loop
RECONCILE_INTERVAL_SECONDS=10

# Init retries while MinIO notification targets become available
WEBHOOK_RETRIES=12
WEBHOOK_RETRY_SECONDS=5

# Local image tag used when building the controller from this repo
DSIMAGING_STORE_CONTROLLER_IMAGE=dsimaging-store-controller:local
